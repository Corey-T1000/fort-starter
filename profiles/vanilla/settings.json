{
  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git log:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(cat:*)",
      "Bash(date:*)",
      "Bash(fort-status:*)",
      "Bash(fort-notify:*)",
      "Bash(bd:*)",
      "Bash(tab-title:*)",
      "WebSearch"
    ]
  },
  "enableAllProjectMcpServers": false,
  "statusLine": {
    "type": "command",
    "command": "__FORT_ROOT__/core/bin/statusline.sh",
    "padding": 0
  }
}
