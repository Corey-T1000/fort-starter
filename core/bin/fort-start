#!/bin/bash
# Fort Start - Start local tools and verify remote server services
#
# Local (this Mac):
#   - Orbstack sandbox VM
#
# Remote (configured via FORT_REMOTE_IP):
#   - Fort Mail, ntfy, Redis, and all deployed services
#   - Checked but not managed from here — use deploy scripts
#
# Usage: fort-start [--sandbox-only]

set -e

# Source Fort environment
_FORT_ENV="${FORT_ROOT:-$HOME/claudes-fort}/.fort-env"
[ -f "$_FORT_ENV" ] && . "$_FORT_ENV"
FORT_ROOT="${FORT_ROOT:-$HOME/claudes-fort}"

FORT_DIR="$FORT_ROOT"
SANDBOX_VM="fort-sandbox"
REMOTE_HOST="${REMOTE_HOST:-${FORT_REMOTE_IP:-127.0.0.1}}"
MAIL_PORT="${FORT_MAIL_PORT:-8080}"
MAIL_URL="http://${REMOTE_HOST}:${MAIL_PORT}"

# Colors
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

log() { echo -e "${BLUE}[fort]${NC} $1"; }
success() { echo -e "${GREEN}✓${NC} $1"; }
warn() { echo -e "${YELLOW}⚠${NC} $1"; }
error() { echo -e "${RED}✗${NC} $1"; }

# Parse arguments
START_SANDBOX=true

while [[ $# -gt 0 ]]; do
    case $1 in
        --sandbox-only)
            shift
            ;;
        -h|--help)
            echo "Usage: fort-start [--sandbox-only]"
            echo ""
            echo "Starts the Orbstack sandbox and checks remote server services."
            echo ""
            echo "Local:   Orbstack sandbox VM"
            echo "Remote:  Fort Mail, ntfy, Redis (on remote server)"
            echo ""
            echo "To manage remote server: ssh ${FORT_REMOTE_HOST:-remote} 'cd /server/fort && docker compose ...'"
            exit 0
            ;;
        *)
            shift
            ;;
    esac
done

echo ""
echo "  ╔═══════════════════════════════════╗"
echo "  ║        Starting Fort Stack        ║"
echo "  ╚═══════════════════════════════════╝"
echo ""

# --- Local ---
echo -e "  ${BOLD}Local (this Mac)${NC}"

# Check Orbstack sandbox (don't start it — starts on demand via fort-sandbox/fort-shell)
log "Checking Orbstack sandbox..."
if command -v orb &> /dev/null; then
    if orb list 2>/dev/null | grep -q "$SANDBOX_VM.*running"; then
        success "Sandbox running (7GB RAM)"
    elif orb list 2>/dev/null | grep -q "$SANDBOX_VM"; then
        success "Sandbox ready (stopped — starts on demand)"
    else
        warn "Sandbox VM not found. Create with: orb create ubuntu $SANDBOX_VM"
    fi
else
    warn "Orbstack not installed (sandbox unavailable)"
fi

# --- Remote ---
echo ""
echo -e "  ${BOLD}remote server (${REMOTE_HOST})${NC}"

# Check remote server reachability first
if ssh -o ConnectTimeout=3 -o BatchMode=yes ${FORT_REMOTE_HOST:-remote} 'true' &>/dev/null; then
    success "remote server reachable"

    # Check key services
    if curl -s --connect-timeout 3 "${MAIL_URL}/api/status" &>/dev/null; then
        success "Fort Mail healthy at $MAIL_URL"
    else
        warn "Fort Mail not responding — check: ssh ${FORT_REMOTE_HOST:-remote} 'docker logs fort-mail'"
    fi

    if curl -s --connect-timeout 3 "http://${REMOTE_HOST}:9090/v1/health" &>/dev/null; then
        success "ntfy healthy"
    else
        warn "ntfy not responding"
    fi
else
    warn "remote server not reachable (offline or not on network)"
    echo -e "    ${DIM}Fort Mail, ntfy, and deployed services unavailable${NC}"
fi

# --- Summary ---
echo ""
"$FORT_DIR/bin/fort-status" --quiet

echo ""
success "Fort is ready!"
echo ""
echo "  Sandbox:       fort-sandbox \"your task\""
echo "  remote server:      ssh ${FORT_REMOTE_HOST:-remote}"
echo "  Status:        fort-status"
echo "  Stop:          fort-stop"
echo ""
