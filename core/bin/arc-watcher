#!/bin/bash
# Arc Inbox Watcher
#
# Monitors Arc's StorableSidebar.json for new pins in the Inbox space
# and sends them to the visual-capture service on the remote server.
#
# Usage:
#   arc-watcher              # Run once (check for new pins)
#   arc-watcher --daemon     # Run continuously
#   arc-watcher --list       # List current Inbox pins
#
# Prerequisites:
#   - jq installed (brew install jq)
#   - Arc Inbox space created
#   - visual-capture service running on the remote server

set -e

# Source Fort environment
_FORT_ENV="${FORT_ROOT:-$HOME/claudes-fort}/.fort-env"
[ -f "$_FORT_ENV" ] && . "$_FORT_ENV"
FORT_ROOT="${FORT_ROOT:-$HOME/claudes-fort}"

ARC_SIDEBAR="$HOME/Library/Application Support/Arc/StorableSidebar.json"
STATE_FILE="$HOME/.local/share/arc-watcher/processed.txt"
CAPTURE_URL="${CAPTURE_URL:-http://${FORT_REMOTE_IP:-127.0.0.1}:3003/capture}"
INBOX_SPACE_NAME="${INBOX_SPACE_NAME:-Inbox}"

# Colors
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

# Ensure state directory exists
mkdir -p "$(dirname "$STATE_FILE")"
touch "$STATE_FILE"

# Get the Inbox space ID by name
get_inbox_space_id() {
    local space_name="$1"
    # Look in firebaseSyncState.syncData.items for space definitions
    jq -r --arg name "$space_name" '
        .firebaseSyncState.syncData.items[]
        | objects
        | select(.value.title == $name)
        | .value.id
    ' "$ARC_SIDEBAR" 2>/dev/null | head -1
}

# Get pinned tabs from Inbox space (items with parentID matching space ID)
get_pinned_tabs() {
    local space_id="$1"
    jq -r --arg sid "$space_id" '
        [.firebaseSyncState.syncData.items[]
         | objects
         | select(.value.parentID == $sid and .value.data.tab.savedURL != null)
         | {
            id: .value.id,
            title: (.value.data.tab.savedTitle // "Untitled"),
            url: .value.data.tab.savedURL
         }]
    ' "$ARC_SIDEBAR" 2>/dev/null
}

# Check if URL was already processed
is_processed() {
    grep -qF "$1" "$STATE_FILE" 2>/dev/null
}

# Mark URL as processed
mark_processed() {
    echo "$1" >> "$STATE_FILE"
}

# Send URL to capture service
capture_url() {
    local url="$1"
    local title="$2"

    echo -e "${BLUE}[Capture]${NC} $title"
    echo -e "         $url"

    response=$(curl -s -X POST "$CAPTURE_URL" \
        -H "Content-Type: application/json" \
        -d "{\"url\": \"$url\"}" 2>/dev/null)

    if echo "$response" | jq -e '.success' &>/dev/null; then
        capture_id=$(echo "$response" | jq -r '.captureId')
        echo -e "${GREEN}[Done]${NC}    Captured as: $capture_id"
        mark_processed "$url"
        return 0
    else
        error=$(echo "$response" | jq -r '.error // "Unknown error"')
        echo -e "${YELLOW}[Error]${NC}   $error"
        return 1
    fi
}

# Main check function
check_inbox() {
    echo -e "${BLUE}[Arc Watcher]${NC} Checking for new pins..."

    # Find Inbox space
    space_id=$(get_inbox_space_id "$INBOX_SPACE_NAME")

    if [ -z "$space_id" ]; then
        echo -e "${YELLOW}[Warning]${NC} Inbox space not found. Create a space named '$INBOX_SPACE_NAME' in Arc."
        return 1
    fi

    echo -e "${BLUE}[Arc Watcher]${NC} Found Inbox space: $space_id"

    # Get pinned tabs
    tabs=$(get_pinned_tabs "$space_id")
    count=$(echo "$tabs" | jq 'length')

    if [ "$count" -eq 0 ]; then
        echo -e "${GREEN}[Arc Watcher]${NC} Inbox is empty"
        return 0
    fi

    echo -e "${BLUE}[Arc Watcher]${NC} Found $count pins in Inbox"

    # Process each tab
    new_count=0
    echo "$tabs" | jq -c '.[]' | while read -r tab; do
        url=$(echo "$tab" | jq -r '.url')
        title=$(echo "$tab" | jq -r '.title')

        if is_processed "$url"; then
            echo -e "  [Skip] Already processed: $title"
        else
            capture_url "$url" "$title"
            new_count=$((new_count + 1))
        fi
    done

    echo -e "${GREEN}[Arc Watcher]${NC} Done"
}

# List current Inbox pins
list_inbox() {
    space_id=$(get_inbox_space_id "$INBOX_SPACE_NAME")

    if [ -z "$space_id" ]; then
        echo "Inbox space not found. Create a space named '$INBOX_SPACE_NAME' in Arc."
        return 1
    fi

    echo "Inbox space ID: $space_id"
    echo ""
    echo "Pinned tabs:"
    get_pinned_tabs "$space_id" | jq -r '.[] | "  - \(.title)\n    \(.url)"'
}

# Daemon mode - watch for changes
run_daemon() {
    echo -e "${BLUE}[Arc Watcher]${NC} Starting daemon mode..."
    echo "Press Ctrl+C to stop"

    while true; do
        check_inbox
        sleep 60
    done
}

# Parse arguments
case "${1:-}" in
    --daemon|-d)
        run_daemon
        ;;
    --list|-l)
        list_inbox
        ;;
    --help|-h)
        echo "Usage: arc-watcher [--daemon|--list|--help]"
        echo ""
        echo "Options:"
        echo "  --daemon, -d   Run continuously, checking every 60s"
        echo "  --list, -l     List current Inbox pins"
        echo "  --help, -h     Show this help"
        ;;
    *)
        check_inbox
        ;;
esac
