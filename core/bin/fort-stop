#!/bin/bash
# Fort Stop - Stop the Fort stack
#
# Components:
#   - Orbstack sandbox VM (local) - stopped by this script
#   - Fort Mail (remote, on remote server) - NOT stopped by this script
#
# Usage: fort-stop

set -e

# Source Fort environment
_FORT_ENV="${FORT_ROOT:-$HOME/claudes-fort}/.fort-env"
[ -f "$_FORT_ENV" ] && . "$_FORT_ENV"
FORT_ROOT="${FORT_ROOT:-$HOME/claudes-fort}"

FORT_DIR="$FORT_ROOT"
SANDBOX_VM="fort-sandbox"

# Colors
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

log() { echo -e "${BLUE}[fort]${NC} $1"; }
success() { echo -e "${GREEN}✓${NC} $1"; }
warn() { echo -e "${YELLOW}⚠${NC} $1"; }
error() { echo -e "${RED}✗${NC} $1"; }

# Parse arguments
while [[ $# -gt 0 ]]; do
    case $1 in
        -h|--help)
            echo "Usage: fort-stop"
            echo ""
            echo "Stops the Orbstack sandbox VM."
            echo ""
            echo "Fort Mail runs on remote server and is NOT stopped by this script."
            echo "To stop Fort Mail: ssh ${FORT_REMOTE_HOST:-remote} 'cd /server/fort && docker compose down'"
            exit 0
            ;;
        *)
            shift
            ;;
    esac
done

echo ""
echo "  ╔═══════════════════════════════════╗"
echo "  ║        Stopping Fort Stack        ║"
echo "  ╚═══════════════════════════════════╝"
echo ""

# Clean up old PID file if it exists (from before migration to remote server)
PID_FILE="$FORT_DIR/.fort-mail.pid"
if [ -f "$PID_FILE" ]; then
    rm -f "$PID_FILE"
fi

# Stop Orbstack sandbox
log "Checking Orbstack sandbox..."
if command -v orb &> /dev/null; then
    if orb list 2>/dev/null | grep -q "$SANDBOX_VM.*running"; then
        log "Stopping sandbox VM..."
        orb stop "$SANDBOX_VM"
        success "Sandbox stopped"
    else
        success "Sandbox already stopped"
    fi
else
    warn "Orbstack not installed"
fi

echo ""
success "Fort stopped!"
echo ""
echo "  Note: Fort Mail on remote server was NOT stopped."
echo "  To stop it: ssh ${FORT_REMOTE_HOST:-remote} 'cd /server/fort && docker compose down'"
echo ""
