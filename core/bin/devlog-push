#!/bin/bash
# Generate daily devlog via webhook + Claude API
# Runs via launchd at 10:30 PM nightly
#
# Gathers today's work data, sends to automation webhook on remote server,
# which calls Claude API and returns the generated devlog markdown.
# This script writes it to the knowledge base and Fort reference.

set -e

# Source Fort environment
_FORT_ENV="${FORT_ROOT:-$HOME/claudes-fort}/.fort-env"
[ -f "$_FORT_ENV" ] && . "$_FORT_ENV"
FORT_ROOT="${FORT_ROOT:-$HOME/claudes-fort}"

FORT_DIR="$FORT_ROOT"
REMOTE="${FORT_REMOTE_IP:-127.0.0.1}"
TODAY=$(date +%Y-%m-%d)
KB_DEVLOG="${FORT_KNOWLEDGE_BASE:-$HOME/knowledge-base}/50 Fort Infrastructure/Devlog"
FORT_DEVLOG="$FORT_DIR/notes/devlog"

TMPDIR=$(mktemp -d)
trap "rm -rf $TMPDIR" EXIT

# 1. Gather data into temp files
if [ -f "$FORT_DIR/logs/$TODAY.md" ]; then
    cp "$FORT_DIR/logs/$TODAY.md" "$TMPDIR/session.txt"
else
    echo "No session log for $TODAY" > "$TMPDIR/session.txt"
fi

cd "$FORT_DIR"
git log --since="today 00:00" --oneline --all --no-merges > "$TMPDIR/git.txt" 2>/dev/null || echo "No commits today" > "$TMPDIR/git.txt"
bd list --status=closed 2>/dev/null | head -30 > "$TMPDIR/closed.txt" || echo "No closed beads" > "$TMPDIR/closed.txt"
bd list --status=in_progress 2>/dev/null | head -20 > "$TMPDIR/active.txt" || echo "No active beads" > "$TMPDIR/active.txt"

# 2. Build JSON payload safely via Python
python3 -c "
import json, os
from datetime import datetime

tmpdir = '$TMPDIR'
today = '$TODAY'

def read(f):
    try:
        with open(os.path.join(tmpdir, f)) as fh:
            return fh.read()
    except:
        return '(not available)'

d = datetime.strptime(today, '%Y-%m-%d')
pretty = d.strftime('%B %-d, %Y')

payload = json.dumps({
    'dateStr': today,
    'prettyDate': pretty,
    'sessionLog': read('session.txt'),
    'gitLog': read('git.txt'),
    'beadsClosed': read('closed.txt'),
    'beadsActive': read('active.txt')
})

with open(os.path.join(tmpdir, 'payload.json'), 'w') as f:
    f.write(payload)
"

# 3. POST to automation webhook (waits for Claude API response)
echo "Sending to webhook..."
RESPONSE=$(curl -s -X POST "http://$REMOTE:5678/webhook/devlog-generate" \
    -H "Content-Type: application/json" \
    --max-time 60 \
    -d @"$TMPDIR/payload.json")

# 4. Extract content from response and write to files
CONTENT=$(echo "$RESPONSE" | python3 -c "
import sys, json
try:
    data = json.load(sys.stdin)
    if isinstance(data, list):
        data = data[0]
    print(data.get('content', ''))
except:
    print('')
")

if [ -z "$CONTENT" ]; then
    echo "ERROR: No content in response"
    echo "Response: $RESPONSE"
    exit 1
fi

# Write to knowledge base (source of truth)
mkdir -p "$KB_DEVLOG"
echo "$CONTENT" > "$KB_DEVLOG/$TODAY.md"

# Write Fort reference copy
mkdir -p "$FORT_DEVLOG"
echo "$CONTENT" > "$FORT_DEVLOG/$TODAY.md"

echo "Devlog generated for $TODAY"
echo "  Knowledge base: $KB_DEVLOG/$TODAY.md"
echo "  Fort ref: $FORT_DEVLOG/$TODAY.md"

# 5. Rebuild and deploy site
echo "Rebuilding site..."
bash "$FORT_DIR/deploy/fort-devlog/deploy.sh" 2>&1 | tail -5

echo "Done!"
